# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Liveblocks Configuration
VITE_LIVEBLOCKS_PUBLIC_KEY=your_liveblocks_public_key

# AI Model Configuration
# Uncomment and set the appropriate API key for your preferred AI service

# OpenAI API Key
# VITE_OPENAI_API_KEY=your_openai_api_key

# Anthropic API Key
# VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# Google AI API Key (for Gemini)
# VITE_GOOGLE_AI_API_KEY=your_google_ai_api_key

# Hugging Face API Key (for open source models)
# VITE_HUGGING_FACE_API_KEY=your_hugging_face_api_key